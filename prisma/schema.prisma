generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campanha {
  id              String   @id @default(cuid())
  slug            String   @unique
  nome            String
  valorPremio     Float
  precoTitulo     Float
  totalTitulos    Int
  titulosVendidos Int      @default(0)
  status          String   @default("ativa") // "ativa" | "concluida"
  dataConclusao   DateTime?
  imagemUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  titulos   Titulo[]
  reservas  Reserva[]
  ganhador  Ganhador?
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  sobrenome String?
  cpf       String?  @unique
  telefone  String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())

  titulos   Titulo[]
  reservas  Reserva[]
  ganhadores Ganhador[]
}

enum StatusReserva {
  reservada
  paga
  expirada
  cancelada
}

enum StatusTitulo {
  reservado
  pago
  expirado
  cancelado
}

model Reserva {
  id          String        @id @default(cuid())
  status      StatusReserva @default(reservada)
  quantidade  Int
  total       Float
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Integração Mercado Pago
  mpPaymentId   String? @unique
  mpPreferenceId String?
  externalReference String? @unique

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  campanhaId String

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  titulos   Titulo[]

  @@index([campanhaId, status, expiresAt])
  @@index([usuarioId, createdAt])
}

model Titulo {
  id          String   @id @default(cuid())
  numeroSorte Int
  createdAt   DateTime @default(now())
  status      StatusTitulo @default(reservado)
  expiresAt   DateTime?

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  campanhaId String

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  reserva   Reserva? @relation(fields: [reservaId], references: [id], onDelete: SetNull)
  reservaId String?

  ganhador  Ganhador?

  @@unique([campanhaId, numeroSorte])
  @@index([campanhaId, status, expiresAt])
}

model Ganhador {
  id             String   @id @default(cuid())
  dataPremiacao  DateTime @default(now())

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  campanhaId String   @unique

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  titulo   Titulo @relation(fields: [tituloId], references: [id], onDelete: Cascade)
  tituloId String @unique
}

