generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campanha {
  id              String   @id @default(cuid())
  slug            String   @unique
  nome            String
  valorPremio     Float
  precoTitulo     Float
  totalTitulos    Int
  titulosVendidos Int      @default(0)
  status          String   @default("ativa") // "ativa" | "concluida"
  dataConclusao   DateTime?
  imagemUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  titulos   Titulo[]
  ganhador  Ganhador?
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  sobrenome String?
  cpf       String?  @unique
  telefone  String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())

  titulos   Titulo[]
  ganhadores Ganhador[]
}

model Titulo {
  id          String   @id @default(cuid())
  numeroSorte Int
  createdAt   DateTime @default(now())

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  campanhaId String

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  ganhador  Ganhador?
}

model Ganhador {
  id             String   @id @default(cuid())
  dataPremiacao  DateTime @default(now())

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  campanhaId String   @unique

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  titulo   Titulo @relation(fields: [tituloId], references: [id], onDelete: Cascade)
  tituloId String @unique
}

